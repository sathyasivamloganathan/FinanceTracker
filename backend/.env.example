# ============================================================================
# COPY THIS FILE TO ".env" IN THE SAME FOLDER AND FILL IN YOUR REAL VALUES.
# Never commit the real ".env" file to git — it's already in .gitignore.
# ============================================================================

# ---- Server ----
PORT=4000
NODE_ENV=development
# Comma-separated list of frontend origins allowed to call this API
CLIENT_ORIGINS=http://localhost:3000

# ---- MongoDB ----
# CHANGE THIS: your real MongoDB connection string (MongoDB Atlas or self-hosted).
# Example Atlas format:
# mongodb+srv://<username>:<password>@<cluster-url>/Finance Tracker?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/Finance Tracker_dev

# ---- Auth / JWT ----
# CHANGE THIS: a long random secret. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET_DO_NOT_USE_THIS_DUMMY_VALUE
# Sessions expire after 7 days -> this is what forces the weekly logout
JWT_EXPIRES_IN=7d
COOKIE_MAX_AGE_MS=604800000

# ---- Email (SMTP) — used for month-end summary + insurance/deadline reminders ----
# CHANGE THIS: use a real provider. For Gmail you must create an "App Password"
# (Google Account -> Security -> 2-Step Verification -> App Passwords) — do NOT
# use your normal Gmail password here. Any SMTP provider works (SendGrid, SES,
# Mailgun, Postmark, your own mail server, etc.) — just change HOST/PORT/USER/PASS.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=REPLACE_WITH_YOUR_SMTP_USERNAME@example.com
EMAIL_PASS=REPLACE_WITH_YOUR_SMTP_PASSWORD_OR_APP_PASSWORD
EMAIL_FROM="Finance Tracker <REPLACE_WITH_YOUR_SMTP_USERNAME@example.com>"

# ---- Prices ----
# Stock and mutual fund prices sync automatically once a day from two free,
# keyless sources (Yahoo Finance for stocks, AMFI's official NAV file for
# mutual funds) — nothing to configure here. See README section 4 for the
# symbol format each one needs, and src/services/priceSyncService.js if you
# want to swap in a different provider later. Gold has no equivalent free
# source and stays manual.
